# ─────────────────────────────────────────────────────────────────────────────
# PCG API — Environment Configuration
# Copy to .env: cp .env.example .env
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
TRUST_PROXY=1

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose):
DATABASE_URL=postgresql://pcg:pcg_secret@localhost:5432/pcg_db

# ── Auth — Access Tokens ─────────────────────────────────────────────────────
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-generate-a-random-32-byte-hex-string
JWT_EXPIRES_IN=15m

# ── Auth — Refresh Tokens ────────────────────────────────────────────────────
JWT_REFRESH_SECRET=change-me-generate-another-random-32-byte-hex-string
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── AI (optional) ────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Administration ────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@pcg.dev
