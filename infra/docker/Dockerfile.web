# infra/docker/Dockerfile.web

FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
WORKDIR /app

# ── Install dependencies ──────────────────────────────────────────────────────

FROM base AS deps
COPY package.json turbo.json ./
COPY apps/web/package.json     ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN npm ci --workspace=apps/web --workspace=packages/shared

# ── Development target (used by docker-compose) ──────────────────────────────

FROM base AS dev
COPY --from=deps /app/node_modules ./node_modules
COPY . .
EXPOSE 3000
CMD ["npx", "turbo", "run", "dev", "--filter=@pcg/web"]

# ── Build ─────────────────────────────────────────────────────────────────────

FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npx turbo run build --filter=@pcg/shared
RUN npx turbo run build --filter=@pcg/web

# ── Production image ──────────────────────────────────────────────────────────

FROM node:20-alpine AS runner
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid  1001 nextjs

COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs
EXPOSE 3000
ENV NODE_ENV=production PORT=3000

CMD ["node", "apps/web/server.js"]
