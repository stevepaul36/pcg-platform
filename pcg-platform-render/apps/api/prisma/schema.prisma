// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  avatarUrl       String?
  // Subscription
  plan            String    @default("free")  // "free" | "student" | "personal"
  emailDomain     String?                     // detected at registration
  subscriptionEnd DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  projects        Project[]
  sessions        Session[]
  refreshTokens   RefreshToken[]
  votes           UserVote[]
  passwordResets  PasswordReset[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// New: rotating refresh tokens — separate from short-lived access-token sessions
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?           // null = still valid
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ── Projects ──────────────────────────────────────────────────────────────────

model Project {
  id            String   @id @default(cuid())
  name          String   @unique   // e.g. "pcg-demo-491a3b7f"
  displayName   String
  ownerId       String
  totalSpendUSD Float    @default(0)  // lifetime accumulated spend in USD
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner        User           @relation(fields: [ownerId], references: [id])
  vms          VMInstance[]
  buckets      StorageBucket[]
  sqlInstances SQLInstance[]
  iamMembers   IAMMember[]
  activityLogs ActivityLog[]

  @@index([ownerId])
}

// ── Compute ───────────────────────────────────────────────────────────────────

model VMInstance {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  zone           String
  region         String
  machineType    String
  vcpus          Int
  ramGb          Float
  diskGb         Int
  diskType       String
  osImage        String
  preemptible    Boolean  @default(false)
  tags           String[]
  internalIp     String
  externalIp     String
  status         String   @default("PROVISIONING")
  // PROVISIONING → RUNNING → STOPPING → TERMINATED
  // RUNNING → STOPPED | SUSPENDED → RUNNING
  hourlyCost     Float
  diskHourlyCost Float
  cpuUsage       Float    @default(0)
  ramUsage       Float    @default(0)
  netIn          Float    @default(0)
  netOut         Float    @default(0)
  uptimeSec      Int      @default(0)
  cpuHistory     Float[]
  ramHistory     Float[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@index([status])
}

// ── Storage ───────────────────────────────────────────────────────────────────

model StorageBucket {
  id             String          @id @default(cuid())
  projectId      String
  name           String          @unique  // globally unique like real GCS
  location       String
  storageClass   String
  versioning     Boolean         @default(false)
  totalSizeBytes BigInt          @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objects        StorageObject[]

  @@index([projectId])
}

model StorageObject {
  id          String        @id @default(cuid())
  bucketId    String
  name        String
  sizeBytes   BigInt
  contentType String
  etag        String
  generation  String
  uploadedAt  DateTime      @default(now())

  bucket      StorageBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)

  @@unique([bucketId, name])
  @@index([bucketId])
}

// ── Cloud SQL ─────────────────────────────────────────────────────────────────

model SQLInstance {
  id               String   @id @default(cuid())
  projectId        String
  name             String
  dbType           String
  dbVersion        String
  tier             String
  region           String
  storageGb        Int
  highAvailability Boolean  @default(false)
  backups          Boolean  @default(true)
  status           String   @default("PENDING_CREATE")
  privateIp        String
  connectionName   String
  hourlyCost       Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}

// ── IAM ───────────────────────────────────────────────────────────────────────

model IAMMember {
  id        String   @id @default(cuid())
  projectId String
  email     String
  role      String
  type      String   @default("user")
  addedAt   DateTime @default(now())
  addedBy   String

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email, role])
  @@index([projectId])
  @@index([email])   // Added: used in requireProjectAccess IAM check
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String
  type        String
  description String
  resourceId  String?
  severity    String   @default("INFO")
  user        String
  metadata    Json     @default("{}")
  timestamp   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([timestamp])
  @@index([type])
}

// ── Announcements ─────────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        String    @default("info")  // "info" | "warning" | "feature" | "maintenance"
  pinned      Boolean   @default(false)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  authorEmail String

  @@index([publishedAt])
  @@index([pinned])
}

// ── Improvement Tracker ───────────────────────────────────────────────────────

model Improvement {
  id          String    @id @default(cuid())
  title       String
  description String
  status      String    @default("planned")  // "planned" | "in_progress" | "completed" | "cancelled"
  priority    String    @default("medium")   // "low" | "medium" | "high" | "critical"
  category    String    @default("feature")  // "feature" | "bug" | "performance" | "ux"
  votes       Int       @default(0)
  authorEmail String    @default("")         // New: track who submitted
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  userVotes   UserVote[]

  @@index([status])
  @@index([priority])
  @@index([votes])
}

// New: per-user votes — prevents duplicate voting
model UserVote {
  id            String      @id @default(cuid())
  userId        String
  improvementId String
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  improvement   Improvement @relation(fields: [improvementId], references: [id], onDelete: Cascade)

  @@unique([userId, improvementId])   // compound unique enforces one vote per user
  @@index([improvementId])
}

// ── Password Reset ────────────────────────────────────────────────────────────

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?          // null = not yet used
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}
