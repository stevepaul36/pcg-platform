# ─────────────────────────────────────────────────────────────────────────────
# PCG API — Environment Configuration
# Copy to .env: cp .env.example .env
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
TRUST_PROXY=1        # set to 0 if running without a reverse proxy

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose):
DATABASE_URL=postgresql://pcg:pcg_dev_pass@localhost:5432/pcg_db

# ── Auth — Access Tokens ─────────────────────────────────────────────────────
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_ME_WITH_32_CHAR_HEX_SECRET_FOR_ACCESS_TOKENS
JWT_EXPIRES_IN=15m

# ── Auth — Refresh Tokens ────────────────────────────────────────────────────
JWT_REFRESH_SECRET=REPLACE_ME_WITH_32_CHAR_HEX_SECRET_FOR_REFRESH_TOKENS
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug    # fatal | error | warn | info | debug | trace

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Administration ────────────────────────────────────────────────────────────
# Comma-separated list of admin emails.
ADMIN_EMAILS=admin@yourdomain.com
