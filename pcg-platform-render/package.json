{
  "name": "pcg-simulator",
  "version": "3.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev":        "turbo run dev",
    "build":      "turbo run build",
    "test":       "turbo run test",
    "lint":       "turbo run lint",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:deploy":  "cd apps/api && npx prisma migrate deploy",
    "db:seed":    "cd apps/api && npx ts-node src/db/seed.ts"
  },
  "devDependencies": {
    "turbo":      "^1.13.0",
    "typescript": "^5.4.0",
    "prettier":   "^3.2.0",
    "@types/node":"^20.0.0"
  }
}
